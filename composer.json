{
    "name": "digital-garden-llc/ma-php",
    "description": "PHP SDK for miniargus: HTTP request tracing + custom application events, PHP 5.6+",
    "type": "library",
    "license": "Apache-2.0",
    "require": {
        "php": ">=5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^5.7"
    },
    "config": {
        "platform": {
            "php": "5.6.40"
        }
    },
    "autoload": {
        "psr-4": {
            "Miniargus\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Miniargus\\Tests\\": "tests/"
        }
    }
}
